# Server
NODE_ENV=development
PORT=8000

# Firebase (required for real data – Firestore, Auth)
# Option A: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./path/to/your-firebase-service-account.json

# Option B: paste the JSON (or base64) in .env – use single line, no line breaks
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Optional: Sentry
# SENTRY_DSN=

# Supabase (required – DB + Auth)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT Secret: Supabase Dashboard → Project Settings → API → JWT Secret (for verifying access tokens)
SUPABASE_JWT_SECRET=your-jwt-secret

# Optional: DB (used by Prisma config if you add it later)
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
